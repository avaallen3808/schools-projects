# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cms_sekolah"

# ── JWT Auth ─────────────────────────────────────────────
JWT_SECRET="your-super-secret-key-change-this"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# ── Server ───────────────────────────────────────────────
PORT=4000
API_PREFIX=api
CORS_ORIGIN="http://localhost:3000"

# ── Throttling ───────────────────────────────────────────
THROTTLE_LIMIT=60

# ── File Uploads ─────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Redis (future) ──────────────────────────────────────
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ── SMTP (future) ───────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
